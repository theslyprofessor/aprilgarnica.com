---
import { SITE_CONFIG, SOCIAL_LINKS, NAV_LINKS } from '@/lib/constants';
---

<footer class="border-t border-border/40 py-12 bg-card/30">
  <div class="container mx-auto px-4 lg:px-8">
    <div class="max-w-6xl mx-auto">
      <div class="grid md:grid-cols-3 gap-8 mb-8">
        <div>
          <h3 class="font-semibold mb-3" style="font-family: 'Playfair Display', serif;">
            {SITE_CONFIG.name}
          </h3>
          <p class="text-sm text-muted-foreground leading-relaxed">
            Filmmaker, Director of Photography, and visual artist from Tijuana, Mexico.
            Currently studying film at UC Santa Cruz.
          </p>
        </div>
        <div>
          <h3 class="font-semibold mb-3">Explore</h3>
          <ul class="space-y-2 text-sm text-muted-foreground">
            {NAV_LINKS.map(({ label, href }) => (
              <li>
                <a href={href} class="hover:text-primary transition-colors">{label}</a>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="font-semibold mb-3">Connect</h3>
          <ul class="space-y-2 text-sm text-muted-foreground">
            <li>
              <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
                Instagram
              </a>
            </li>
            <li>
              <a href={SOCIAL_LINKS.vimeo} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">
                Vimeo
              </a>
            </li>
            <li>
              <a href={`mailto:${SITE_CONFIG.email}`} class="hover:text-primary transition-colors">
                Email
              </a>
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-border/40 pt-8 text-center text-sm text-muted-foreground">
        <p>&copy; {new Date().getFullYear()} {SITE_CONFIG.name}. All rights reserved.</p>
      </div>
    </div>
  </div>
</footer>
