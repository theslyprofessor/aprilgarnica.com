---
import PageLayout from '@/layouts/PageLayout.astro';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { getAllFilms } from '@/data/films';
import { SITE_CONFIG } from '@/lib/constants';

const films = await getAllFilms();
---

<PageLayout title={`Film — ${SITE_CONFIG.name}`} description="Film portfolio of April Garnica — Director of Photography, narrative and documentary filmmaking.">
  <section class="py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-6xl mx-auto space-y-12">
        <div class="text-center space-y-4">
          <h1 class="text-4xl md:text-5xl font-bold">Film</h1>
          <p class="text-lg text-muted-foreground" style="font-family: 'Inter', sans-serif;">
            Director of Photography &middot; Narrative &middot; Documentary
          </p>
        </div>

        <!-- DP Reel placeholder -->
        <div class="max-w-4xl mx-auto">
          <div class="cinema-ratio bg-card rounded-lg flex items-center justify-center border border-border/50">
            <div class="text-center space-y-3">
              <p class="text-2xl font-bold text-muted-foreground/50">DP Reel</p>
              <p class="text-sm text-muted-foreground">Vimeo embed coming soon</p>
            </div>
          </div>
        </div>

        <!-- Film Projects -->
        <div>
          <h2 class="text-2xl font-bold mb-8">Projects</h2>
          <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {films.map((film) => (
              <a href={`/film/${film.id}`} class="group">
                <Card className="h-full hover:border-primary/50 transition-all duration-300 overflow-hidden">
                  <div class="cinema-ratio bg-gradient-to-br from-primary/10 to-accent/5 flex items-center justify-center">
                    <p class="text-4xl font-bold text-muted-foreground/20">{film.data.title[0]}</p>
                  </div>
                  <CardHeader>
                    <div class="flex items-center justify-between">
                      <CardTitle className="text-lg group-hover:text-primary transition-colors">
                        {film.data.title}
                      </CardTitle>
                      <span class="text-sm text-muted-foreground">{film.data.year}</span>
                    </div>
                    <CardDescription>{film.data.role}</CardDescription>
                  </CardHeader>
                  <CardContent>
                    <p class="text-sm text-muted-foreground line-clamp-2">{film.data.logline}</p>
                    {film.data.festivals.length > 0 && (
                      <div class="flex flex-wrap gap-1 mt-3">
                        {film.data.festivals.map((f) => (
                          <span class="text-xs text-laurel border border-[hsl(var(--laurel-gold))]/30 px-2 py-0.5 rounded-full">
                            {f.name}
                          </span>
                        ))}
                      </div>
                    )}
                  </CardContent>
                </Card>
              </a>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
