---
import PageLayout from '@/layouts/PageLayout.astro';
import { Card, CardContent, CardHeader, CardTitle, CardDescription } from '@/components/ui/card';
import { getAllBlogPosts } from '@/data/blog';
import { SITE_CONFIG } from '@/lib/constants';
import AnimatedSection, { AnimatedItem } from '@/components/react/AnimatedSection';

const posts = await getAllBlogPosts();
---

<PageLayout title={`Blog — ${SITE_CONFIG.name}`} description="Thoughts on filmmaking, photography, and the creative process.">
  <section class="py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto space-y-12">
        <AnimatedSection variant="fadeUp" client:visible>
          <div class="text-center space-y-4">
            <h1 class="text-4xl md:text-5xl font-bold">Blog</h1>
            <p class="text-lg text-muted-foreground" style="font-family: 'Inter', sans-serif;">
              Thoughts on filmmaking, photography, and the creative process
            </p>
          </div>
        </AnimatedSection>

        <AnimatedSection stagger staggerDelay={0.1} className="space-y-6" client:visible>
          {posts.length === 0 && (
            <AnimatedItem variant="fadeUp">
              <p class="text-center text-muted-foreground py-12" style="font-family: 'Inter', sans-serif;">
                No posts yet. Check back soon!
              </p>
            </AnimatedItem>
          )}
          {posts.map((post) => (
            <AnimatedItem variant="fadeUp">
              <a href={`/blog/${post.id}`} class="block group">
                <Card className="hover:border-primary/50 transition-all duration-300">
                  <CardHeader>
                    <div class="flex items-center gap-3 text-sm text-muted-foreground mb-2" style="font-family: 'Inter', sans-serif;">
                      <time datetime={post.data.publishDate.toISOString()}>
                        {post.data.publishDate.toLocaleDateString('en-US', {
                          year: 'numeric',
                          month: 'long',
                          day: 'numeric',
                        })}
                      </time>
                      {post.data.tags.length > 0 && (
                        <>
                          <span>&middot;</span>
                          <div class="flex gap-1">
                            {post.data.tags.map((tag) => (
                              <span class="text-xs text-primary">{tag}</span>
                            ))}
                          </div>
                        </>
                      )}
                    </div>
                    <CardTitle className="text-xl group-hover:text-primary transition-colors">
                      {post.data.title}
                    </CardTitle>
                    <CardDescription>{post.data.description}</CardDescription>
                  </CardHeader>
                </Card>
              </a>
            </AnimatedItem>
          ))}
        </AnimatedSection>
      </div>
    </div>
  </section>
</PageLayout>
