---
import PageLayout from '@/layouts/PageLayout.astro';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { SITE_CONFIG, SOCIAL_LINKS } from '@/lib/constants';
---

<PageLayout title={`Contact — ${SITE_CONFIG.name}`} description="Get in touch with April Garnica for film projects, photography, and creative collaborations.">
  <section class="py-20">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mx-auto space-y-12">
        <div class="text-center space-y-4">
          <h1 class="text-4xl md:text-5xl font-bold">Contact</h1>
          <p class="text-lg text-muted-foreground" style="font-family: 'Inter', sans-serif;">
            Available for film projects, photography, and creative collaborations
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          <Card className="hover:border-primary/50 transition-colors">
            <CardHeader>
              <CardTitle className="text-lg">Film & Video</CardTitle>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-muted-foreground" style="font-family: 'Inter', sans-serif;">
                Director of Photography, narrative film, documentary, music videos, and commercial projects.
              </p>
            </CardContent>
          </Card>

          <Card className="hover:border-primary/50 transition-colors">
            <CardHeader>
              <CardTitle className="text-lg">Photography & Art</CardTitle>
            </CardHeader>
            <CardContent>
              <p class="text-sm text-muted-foreground" style="font-family: 'Inter', sans-serif;">
                Portrait sessions, event photography, editorial, and commissioned artwork.
              </p>
            </CardContent>
          </Card>
        </div>

        <div class="text-center space-y-6">
          <div class="flex flex-col sm:flex-row gap-4 justify-center">
            <Button size="lg">
              <a href={`mailto:${SITE_CONFIG.email}`}>Email Me</a>
            </Button>
            <Button size="lg" variant="outline">
              <a href={SOCIAL_LINKS.instagram} target="_blank" rel="noopener noreferrer">
                Instagram
              </a>
            </Button>
            <Button size="lg" variant="outline">
              <a href={SOCIAL_LINKS.vimeo} target="_blank" rel="noopener noreferrer">
                Vimeo
              </a>
            </Button>
          </div>

          <p class="text-sm text-muted-foreground" style="font-family: 'Inter', sans-serif;">
            Based in Santa Cruz, CA &middot; Originally from Tijuana, MX
          </p>
        </div>
      </div>
    </div>
  </section>
</PageLayout>
